# -----------------------------------------------------------------------
# Authentication (Keycloak)
#
# VITE_KEYCLOAK_URL must be reachable FROM THE USER'S BROWSER — not from
# the Docker network. In local dev Keycloak is port-forwarded to :8080,
# so localhost:8080 is correct. In production, use the public HTTPS URL.
#
# Why the browser talks to Keycloak directly:
#   This is standard OIDC Authorization Code + PKCE flow. The browser
#   redirects to Keycloak for login, receives a JWT, and then sends that
#   JWT to the backend on every API call. The backend verifies the JWT
#   against Keycloak's JWKS endpoint (server-to-server, not user-facing).
# -----------------------------------------------------------------------
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=saas
VITE_KEYCLOAK_CLIENT_ID=saas-frontend
