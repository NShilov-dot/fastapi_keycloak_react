# Frontend has NO direct knowledge of Keycloak in the BFF model.
#
# All auth flows go through the backend:
#   GET  /api/v1/auth/login    — backend redirects the browser to Keycloak
#   GET  /api/v1/auth/callback — Keycloak posts the user back here
#   POST /api/v1/auth/logout   — terminates the server-side session
#   GET  /api/v1/auth/me       — current user info (from session, not token)
#
# Vite proxies /api/* → http://localhost:8000 in dev (see vite.config.ts).
# No env vars needed for auth.
