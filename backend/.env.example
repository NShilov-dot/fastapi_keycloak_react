APP_ENV=local
APP_DEBUG=true
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://redis:6379/0

KEYCLOAK_ISSUER=http://keycloak:8080/realms/saas
KEYCLOAK_AUDIENCE=saas-backend
KEYCLOAK_JWKS_CACHE_TTL=3600
KEYCLOAK_TENANT_CLAIM=tenant_id

# Keycloak Admin API (leave empty to disable)
KEYCLOAK_REALM=saas
KEYCLOAK_ADMIN_CLIENT_ID=saas-backend-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=

# OIDC client (BFF model: backend is a confidential client and holds the user's tokens)
OIDC_CLIENT_ID=saas-backend
OIDC_CLIENT_SECRET=change-me-in-prod
# URL the browser uses to reach the backend (and that Keycloak redirects to)
PUBLIC_BASE_URL=http://localhost:8000
# URL the browser uses to reach the SPA (post-login / post-logout landing)
FRONTEND_BASE_URL=http://localhost:5173

# Sessions (opaque cookie → Redis-backed token store)
SESSION_COOKIE_NAME=saas_session
SESSION_TTL_SECONDS=36000
SESSION_IDLE_SECONDS=1800

# Rate limiting (per authenticated user, fixed-window in Redis)
RATE_LIMIT_GLOBAL_PER_MINUTE=120
RATE_LIMIT_WRITES_PER_MINUTE=30

# Maximum request body size in bytes (default 1 MB)
MAX_BODY_SIZE_BYTES=1048576

# Restrict Host header to these values in production (comma-separated, empty = disabled)
# TRUSTED_HOSTS=api.example.com

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
