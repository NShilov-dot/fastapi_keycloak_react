# Production environment template. Copy to .env.prod and fill REAL values:
#   cp .env.prod.example .env.prod   (or: make env-prod)
#
# .env.prod is gitignored. It feeds BOTH docker-compose interpolation
# (--env-file .env.prod) AND the app container (env_file). With APP_ENV=prod the
# backend's validate_for_production() refuses to start on weak/missing values.
# Generate encryption keys with: make gen-key

APP_ENV=prod
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# --- Datastores (internal docker network; NOT published in prod) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://app:CHANGE_ME_strong_db_password@postgres:5432/app

# Redis MUST have a password in prod (it holds session tokens at rest).
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
# RATE_LIMIT_REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/1

# --- Keycloak ---
KC_DB_PASSWORD=CHANGE_ME_strong_kcdb_password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_kc_admin_password
KEYCLOAK_REALM=saas
# Public host Keycloak is reached on (browser). Exposed via the edge nginx or your ingress.
KC_HOSTNAME=auth.example.com
# Browser-facing issuer (authorize/end_session + token `iss`) — HTTPS in prod.
KEYCLOAK_PUBLIC_ISSUER=https://auth.example.com/realms/saas
# Keycloak Admin API service account (must match the realm; rotate the dev value!).
KEYCLOAK_ADMIN_CLIENT_ID=saas-backend-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME_admin_service_account_secret

KEYCLOAK_AUDIENCE=saas-backend

# --- OIDC client (BFF) — must match the realm; rotate the dev value! ---
OIDC_CLIENT_ID=saas-backend
OIDC_CLIENT_SECRET=CHANGE_ME_real_oidc_client_secret

# --- Public URLs (single origin behind the edge nginx; HTTPS) ---
PUBLIC_BASE_URL=https://app.example.com
FRONTEND_BASE_URL=https://app.example.com
# Host-header allowlist (required in prod). Comma-separated.
TRUSTED_HOSTS=app.example.com
# CORS only needed if the SPA is on a different origin than the API (usually not, single-origin).
CORS_ORIGINS=https://app.example.com

# --- Sessions / token encryption at rest (REQUIRED in prod) ---
SESSION_COOKIE_NAME=saas_session
SESSION_TTL_SECONDS=36000
SESSION_IDLE_SECONDS=1800
# Base64 AES-256 keys, comma-separated for rotation. Generate: make gen-key
SESSION_ENCRYPTION_KEYS=CHANGE_ME_base64_32byte_key

# --- Rate limiting ---
RATE_LIMIT_GLOBAL_PER_MINUTE=120
RATE_LIMIT_WRITES_PER_MINUTE=30
RATE_LIMIT_TENANT_PER_MINUTE=6000
RATE_LIMIT_AUTH_PER_MINUTE_PER_IP=20
# Strict per-IP cap (1h window) for the expensive public signup endpoint.
RATE_LIMIT_SIGNUP_PER_HOUR_PER_IP=5
# Aggregate signup ceiling across ALL IPs per hour (0 disables) — distributed-source backstop.
RATE_LIMIT_SIGNUP_GLOBAL_PER_HOUR=50

# --- Self-service signup ---
# true = anyone can register a company at POST /v1/signup.
# Set false for invite-only / sales-led onboarding (operator creates tenants only).
SIGNUP_ENABLED=true

MAX_BODY_SIZE_BYTES=1048576
